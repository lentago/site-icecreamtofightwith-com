---
// Editorial layout — implements "Ice Cream to Fight With.dc.html" from the
// Claude Design project "Ice Cream Blog Redesign": warm paper + ink + red,
// Bricolage Grotesque / Newsreader / Space Mono, sticky header with the
// tier key, the filmstrip as primary nav, and per-recipe national-flag
// page backgrounds.
import { getCollection } from 'astro:content';
import Filmstrip from '../components/Filmstrip.astro';
import { getEssays } from '../lib/essays';
import { TIERS } from '../lib/tiers';
import { diagrams } from '../data/diagrams.js';

interface Props {
  title?: string;
  description?: string;
  /** Per-recipe flag background; null/undefined = plain paper. */
  bg?: { base: string; grad: string } | null;
  /** Which filmstrip card is active. */
  active?: { kind: 'recipe' | 'essay'; slug: string };
}

const {
  title = 'Ice Cream to Fight With',
  description = "Recipes You'll Fuck Up At Least Once",
  bg = null,
  active,
} = Astro.props;

// Footer tally, computed from the real data so it can't drift.
const recipeCount = (await getCollection('recipes')).length;
const essayCount = (await getEssays()).length;
const diagramCount = Object.keys(diagrams.figures).length;

const bodyStyle = bg
  ? `background-color:${bg.base};background-image:${bg.grad};background-attachment:fixed;`
  : undefined;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="alternate" type="application/rss+xml" title="Ice Cream to Fight With" href="/rss.xml" />

  <style is:global>
    :root {
      --paper: #F2EADA;
      --panel: #FBF5E9;
      --newsprint: #EDE3CF;
      --ink: #17130F;
      --body: #241f19;
      --muted: #6E6456;
      --red: #A32B29;

      --font-display: 'Bricolage Grotesque', sans-serif;
      --font-serif: 'Newsreader', Georgia, serif;
      --font-mono: 'Space Mono', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: var(--font-serif);
      font-size: 19px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      font-optical-sizing: auto;
    }

    a { color: var(--red); text-decoration: none; }
    a:hover { color: var(--ink); }
    ::selection { background: var(--ink); color: var(--paper); }

    @keyframes icfwfade {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: none; }
    }
    .fade { animation: icfwfade 0.45s ease both; }
    @media (prefers-reduced-motion: reduce) {
      .fade { animation: none; }
    }
  </style>
</head>
<body style={bodyStyle} class:list={[{ 'has-flag': Boolean(bg) }]}>

  <!-- Hand-drawn wobble filter used by the field-diagram SVGs -->
  <svg aria-hidden="true" width="0" height="0" style="position:absolute">
    <defs>
      <filter id="sketch" x="-6%" y="-6%" width="112%" height="112%">
        <feTurbulence type="fractalNoise" baseFrequency="0.016" numOctaves="2" seed="7" result="n"></feTurbulence>
        <feDisplacementMap in="SourceGraphic" in2="n" scale="1.8" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap>
      </filter>
    </defs>
  </svg>

  <div class="shell">
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="wordmark">
          <span class="scoop" aria-hidden="true"></span>
          <span class="wordmark-text">Ice Cream to Fight With</span>
        </a>
        <div class="tier-key" aria-label="Difficulty tiers">
          {TIERS.map((t) => (
            <span class="tier-key-item">
              <span class="tier-swatch" style={`background:${t.color}`}></span>
              <span class="tier-key-label">{t.label}</span>
            </span>
          ))}
        </div>
      </div>
    </header>

    <Filmstrip active={active} />

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div>
          <div class="footer-mark">Ice Cream to Fight With</div>
          <div class="footer-tagline"><span>Recipes You'll Fuck Up At Least Once</span><a
            href="https://pl-preview-e8ef58a5.icecreamtofightwith.com"
            class="footer-dot"
            aria-hidden="true"
            tabindex="-1"
          >.</a></div>
        </div>
        <div class="footer-tally">{recipeCount} recipes · {essayCount} essays · {diagramCount} field diagrams</div>
      </div>
    </footer>
  </div>

<style>
  .shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  main { flex: 1; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    height: 60px;
    background: rgba(242, 234, 218, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(23, 19, 15, 0.15);
  }
  :global(body.has-flag) .site-header {
    background: rgba(251, 250, 246, 0.82);
  }
  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 22px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }
  .wordmark {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .scoop {
    width: 22px;
    height: 22px;
    border-radius: 50% 50% 50% 4px;
    background: var(--red);
    display: inline-block;
    box-shadow: inset 0 -6px 0 rgba(0, 0, 0, 0.14);
  }
  .wordmark-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .tier-key {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .tier-key-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tier-swatch {
    width: 11px;
    height: 11px;
    border-radius: 3px;
    display: inline-block;
  }
  .tier-key-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .site-footer {
    border-top: 2px solid var(--ink);
    background: var(--newsprint);
  }
  :global(body.has-flag) .site-footer {
    background: transparent;
  }
  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 34px 26px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-mark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .footer-tagline {
    font-style: italic;
    color: var(--muted);
    font-size: 16px;
  }
  /* The full stop after the tagline is a doorway, not punctuation —
     the easter egg ported from the old homepage hero. Visually identical
     to a plain period; out of the a11y tree and tab order. */
  .footer-dot,
  .footer-dot:hover,
  .footer-dot:focus,
  .footer-dot:visited {
    color: inherit;
    text-decoration: none;
    outline: none;
  }
  .footer-tally {
    font-family: var(--font-mono);
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .tier-key { display: none; }
  }
</style>
</body>
</html>
