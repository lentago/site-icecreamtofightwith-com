---
import Base from '../layouts/Base.astro';
import Search from 'astro-pagefind/components/Search.astro';
---
<Base title="The Pile — Ice Cream to Fight With" description="Search all 28 issues by name, ingredient, technique, or cultural context.">
  <main class="page-container">
    <header class="search-header">
      <p class="search-kicker kicker">The Pile</p>
      <h1>Dig Through the Stack</h1>
      <p class="search-blurb">Twenty-eight issues, one messy pile. Try a flavor, a technique, a cultural origin, or just a vibe &mdash; live search, no backend, just an index stapled into the zine.</p>
    </header>

    <Search
      id="search"
      className="pagefind-ui"
      uiOptions={{
        showImages: false,
        excerptLength: 28,
        resetStyles: false,
        showSubResults: false,
        placeholder: 'Search recipes…',
      }}
    />
  </main>
</Base>

<style is:global>
  /* Tone Pagefind's default UI down to match the broadsheet palette */
  .pagefind-ui {
    --pagefind-ui-primary: var(--pink);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--panel);
    --pagefind-ui-border: var(--ink);
    --pagefind-ui-tag: var(--paper-2);
    --pagefind-ui-border-width: 2px;
    --pagefind-ui-border-radius: 0px;
    --pagefind-ui-font: var(--font-body);
    --pagefind-ui-image-side-length: 0px;
  }
  .pagefind-ui .pagefind-ui__result-title { font-family: var(--font-display); font-weight: 400; text-transform: uppercase; }
</style>

<style>
  .search-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 3px dashed var(--ink);
    text-align: center;
  }

  .search-kicker { display: block; color: var(--pink); margin-bottom: 0.6rem; }

  .search-header h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.3rem, 6vw, 3.8rem);
    line-height: 0.95;
    text-transform: uppercase;
    margin: 0 0 0.85rem;
    transform: rotate(-1deg);
  }

  .search-blurb {
    font-family: var(--font-marker);
    color: var(--pink-deep);
    font-size: 1.25rem;
    line-height: 1.35;
    max-width: 40rem;
    margin: 0 auto;
  }
</style>
