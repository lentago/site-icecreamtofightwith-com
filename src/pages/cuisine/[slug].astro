---
import Base from '../../layouts/Base.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { cuisineToSlug } from '../../lib/cuisine';

export async function getStaticPaths() {
  const all = await getCollection('recipes');
  const byCuisine = new Map<string, typeof all>();
  for (const recipe of all) {
    const cuisine = recipe.data.cuisine;
    if (!cuisine) continue;
    const bucket = byCuisine.get(cuisine) ?? [];
    bucket.push(recipe);
    byCuisine.set(cuisine, bucket);
  }
  return Array.from(byCuisine.entries()).map(([cuisine, recipes]) => ({
    params: { slug: cuisineToSlug(cuisine) },
    props: { cuisine, recipes },
  }));
}

const { cuisine, recipes } = Astro.props;
const sorted = [...recipes].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base title={`${cuisine} — Ice Cream to Fight With`} description={`${sorted.length} ${cuisine} issue${sorted.length === 1 ? '' : 's'} from Ice Cream to Fight With.`}>
  <main class="page-container wide">
    <header class="desk-header">
      <p class="desk-eyebrow kicker">The Region</p>
      <h1>{cuisine}</h1>
      <p class="desk-count">{sorted.length} {sorted.length === 1 ? 'issue' : 'issues'} from here</p>
    </header>

    <div class="recipe-grid">
      {sorted.map(recipe => (
        <RecipeCard
          slug={recipe.data.recipeSlug}
          title={recipe.data.title}
          subtitle={recipe.data.subtitle}
          number={recipe.data.recipeNumber}
          tier={recipe.data.tier}
          date={recipe.data.date}
        />
      ))}
    </div>
  </main>
</Base>

<style>
  .desk-header {
    margin: 0.5rem 0 2.5rem;
    text-align: center;
    padding-bottom: 1.5rem;
    border-bottom: 3px dashed var(--ink);
  }
  .desk-eyebrow { display: block; margin-bottom: 0.6rem; }
  .desk-header h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.3rem, 6vw, 3.8rem);
    margin: 0 0 0.6rem;
    line-height: 0.95;
    text-transform: uppercase;
    transform: rotate(-1deg);
  }
  .desk-count {
    font-family: var(--font-stencil);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    margin: 0;
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1.75rem;
  }

  @media (max-width: 640px) {
    .recipe-grid { grid-template-columns: 1fr; }
  }
</style>
