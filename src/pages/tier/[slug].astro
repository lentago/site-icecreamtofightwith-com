---
import Base from '../../layouts/Base.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { redactHtml } from '../../lib/redact.mjs';

// Astro hoists getStaticPaths into a separate scope, so TIERS lives
// inside the function. The TS interface stays at module scope.
interface TierMeta {
  slug: string;
  name: string;
  description: string;
}

export async function getStaticPaths() {
  const TIERS = [
    {
      slug: 'chill',
      name: 'CHILL',
      description: "You're making tea, basically. Simple techniques, minimal failure points, maximum reward. Start here if you've never made ice cream before.",
    },
    {
      slug: 'legit',
      name: 'LEGIT',
      description: "Real ice cream making. Custard bases, tempering, infusions. You'll learn technique here, and the results are worth the effort.",
    },
    {
      slug: 'real-deal',
      name: 'THE REAL DEAL',
      description: "Multiple components, timing choreography, and at least one moment where you'll question your life choices. The smug satisfaction when you nail it is unmatched.",
    },
    {
      slug: 'ordeal',
      name: 'A FUCKING ORDEAL',
      description: "Yeasted doughs, multi-day processes, rare seasonal ingredients that spoil in 48 hours. You absolute lunatic. We love you for it.",
    },
  ];
  return TIERS.map(tier => ({
    params: { slug: tier.slug },
    props: { tier },
  }));
}

const { tier } = Astro.props as { tier: TierMeta };
const recipes = (await getCollection('recipes'))
  .filter(r => r.data.tier === tier.name)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base title={`${tier.name} — Ice Cream to Fight With`} description={tier.description}>
  <main class="page-container wide">
    <header class="desk-header">
      <p class="desk-eyebrow kicker">Damage Level</p>
      <h1 class="desk-title"><span class={`tier-badge ${tier.slug}`} set:html={redactHtml(tier.name)} /></h1>
      <p class="desk-count">{recipes.length} {recipes.length === 1 ? 'issue' : 'issues'} at this level</p>
      <hr class="desk-hr" />
      <p class="desk-description" set:html={redactHtml(tier.description)} />
    </header>

    <div class="recipe-grid">
      {recipes.map(recipe => (
        <RecipeCard
          slug={recipe.data.recipeSlug}
          title={recipe.data.title}
          subtitle={recipe.data.subtitle}
          number={recipe.data.recipeNumber}
          tier={recipe.data.tier}
          date={recipe.data.date}
        />
      ))}
    </div>
  </main>
</Base>

<style>
  .desk-header {
    margin: 0.5rem 0 2.5rem;
    text-align: center;
  }
  .desk-eyebrow { display: block; margin-bottom: 0.9rem; }
  .desk-title { margin: 0 0 0.7rem; }
  .desk-title .tier-badge { font-size: 1rem; padding: 0.4rem 0.9rem 0.35rem; }
  .desk-count {
    font-family: var(--font-stencil);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }
  .desk-hr { border: 0; border-top: 2px dashed var(--ink); margin: 1.1rem auto; max-width: 24rem; }
  .desk-description {
    max-width: 40rem;
    margin: 0 auto;
    font-family: var(--font-marker);
    font-size: 1.2rem;
    line-height: 1.35;
    color: var(--pink-deep);
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1.75rem;
  }

  @media (max-width: 640px) {
    .recipe-grid { grid-template-columns: 1fr; }
  }
</style>
