---
import { redactHtml } from '../lib/redact.mjs';
import { formatShort, isoDate } from '../lib/dispatch';

interface Props {
  slug: string;
  title: string;
  subtitle: string;
  number: number;
  tier: string;        // raw tier name (CHILL / LEGIT / THE REAL DEAL / A FUCKING ORDEAL)
  date: Date;
}

const { slug, title, subtitle, number, tier, date } = Astro.props;

const TIER_CLASS: Record<string, string> = {
  'CHILL': 'chill',
  'LEGIT': 'legit',
  'THE REAL DEAL': 'real-deal',
  'A FUCKING ORDEAL': 'ordeal',
};
const tierClass = TIER_CLASS[tier] ?? 'legit';
const issue = '#' + String(number).padStart(2, '0');
---
<a href={`/recipes/${slug}/`} class="clipping">
  <div class="clipping-top">
    <span class="clipping-issue">Issue&nbsp;{issue}</span>
    <time datetime={isoDate(date)}>{formatShort(date)}</time>
  </div>
  <span class={`tier-badge ${tierClass}`} set:html={redactHtml(tier)} />
  <h3>{title}</h3>
  <p class="clipping-deck">{subtitle}</p>
</a>

<style>
  .clipping {
    display: block;
    background: var(--panel);
    border: 3px solid var(--ink);
    padding: 1rem 1.1rem 1.15rem;
    text-decoration: none;
    color: var(--ink);
    box-shadow: 5px 5px 0 var(--ink);
    transform: rotate(-1deg);
    transition: transform 0.14s ease, box-shadow 0.14s ease;
  }
  .clipping:hover {
    transform: rotate(0deg) translate(-2px, -2px);
    box-shadow: 7px 7px 0 var(--pink);
  }

  .clipping-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    font-family: var(--font-stencil);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-soft);
    margin-bottom: 0.55rem;
  }
  .clipping-issue { color: var(--pink); }

  .clipping h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.45rem;
    line-height: 0.98;
    text-transform: uppercase;
    margin: 0.5rem 0 0.4rem;
  }

  .clipping-deck {
    font-family: var(--font-marker);
    font-size: 0.98rem;
    color: var(--pink-deep);
    line-height: 1.2;
  }
</style>
