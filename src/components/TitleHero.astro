---
// TitleHero — viewport-filling title graphic for the homepage.
// Sits above EssayArticle so the intro's first paragraph starts below
// the fold on a typical desktop. Issue #132.
//
// Entrance animation uses the global .fade class from Base.astro, which
// already gates on prefers-reduced-motion.
---

<section class="title-hero">
  <div class="hero-inner fade">
    <div class="hero-mark" aria-hidden="true">
      <!-- Scoop shape echoing the favicon (public/favicon.svg) and the
           header's CSS .scoop mark: border-radius 50% 50% 50% 4px in --red
           with the inset bottom shadow band. -->
      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
        <defs>
          <clipPath id="hero-scoop-clip">
            <path d="M8,40 A32 32 0 0 1 40,8 A32 32 0 0 1 72,40 A32 32 0 0 1 40,72 L14,72 A6 6 0 0 1 8,66 Z"/>
          </clipPath>
        </defs>
        <path d="M8,40 A32 32 0 0 1 40,8 A32 32 0 0 1 72,40 A32 32 0 0 1 40,72 L14,72 A6 6 0 0 1 8,66 Z" fill="var(--red)"/>
        <rect x="0" y="56" width="80" height="24" fill="#000" fill-opacity="0.14" clip-path="url(#hero-scoop-clip)"/>
      </svg>
    </div>

    <p class="hero-title">Ice Cream<br>to <span class="hero-fight">Fight</span> With</p>
    <p class="hero-tagline">Recipes You'll Screw Up At Least Once</p>
  </div>
</section>

<style>
  .title-hero {
    /* Tall enough to read as a hero and keep the intro's first line near
       the fold, but trimmed from a full 100vh so the title isn't marooned
       in dead space below the filmstrip. 72svh avoids the mobile toolbar
       trap. Content stays vertically centered within this shorter band. */
    min-height: calc(72vh - 60px);
    min-height: calc(72svh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(24px, 4vw, 44px) 26px;
    border-bottom: 2px solid var(--ink);
  }

  .hero-inner {
    text-align: center;
    max-width: 1000px;
    width: 100%;
  }

  .hero-mark {
    margin: 0 auto clamp(20px, 4vw, 44px);
    width: clamp(60px, 10vw, 108px);
    height: clamp(60px, 10vw, 108px);
  }

  .hero-mark svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(46px, 10.5vw, 140px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 clamp(18px, 3vw, 40px);
    overflow-wrap: break-word;
    /* The size ramp above keeps "to Fight With" on one line even with the
       wide calligraphic Fight; balance is a safeguard against a stray
       "With" being orphaned if the copy ever lengthens. */
    text-wrap: balance;
  }

  /* "Fight" set as fancy calligraphic script in red — the one flourish in
     an otherwise bold grotesque wordmark. Great Vibes has a small x-height
     and long ascenders/descenders, so scale it up to sit optically level
     with the grotesque caps, drop the grotesque's tight tracking, and give
     the swashes vertical room so they aren't clipped by the tight leading. */
  .hero-fight {
    font-family: var(--font-script);
    font-weight: 400;
    font-style: normal;
    color: var(--red);
    font-size: 1.32em;
    letter-spacing: normal;
    line-height: 1;
    padding: 0 0.06em;
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: clamp(11px, 1.5vw, 17px);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--red);
    margin: 0;
  }
</style>
