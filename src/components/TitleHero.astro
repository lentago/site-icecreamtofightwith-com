---
// TitleHero — viewport-filling title graphic for the homepage.
// Sits above EssayArticle so the intro's first paragraph starts below
// the fold on a typical desktop. Issue #132.
//
// Entrance animation uses the global .fade class from Base.astro, which
// already gates on prefers-reduced-motion.
---

<section class="title-hero">
  <div class="hero-inner fade">
    <div class="hero-mark" aria-hidden="true">
      <!-- Scoop shape echoing the favicon (public/favicon.svg) and the
           header's CSS .scoop mark: border-radius 50% 50% 50% 4px in --red
           with the inset bottom shadow band. -->
      <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
        <defs>
          <clipPath id="hero-scoop-clip">
            <path d="M8,40 A32 32 0 0 1 40,8 A32 32 0 0 1 72,40 A32 32 0 0 1 40,72 L14,72 A6 6 0 0 1 8,66 Z"/>
          </clipPath>
        </defs>
        <path d="M8,40 A32 32 0 0 1 40,8 A32 32 0 0 1 72,40 A32 32 0 0 1 40,72 L14,72 A6 6 0 0 1 8,66 Z" fill="var(--red)"/>
        <rect x="0" y="56" width="80" height="24" fill="#000" fill-opacity="0.14" clip-path="url(#hero-scoop-clip)"/>
      </svg>
    </div>

    <p class="hero-title">Ice Cream<br>to Fight With</p>
    <p class="hero-tagline">Recipes You'll Screw Up At Least Once</p>
  </div>
</section>

<style>
  .title-hero {
    /* Fill the viewport below the sticky 60px header so the intro starts
       below the fold. 100svh avoids the mobile browser toolbar trap. */
    min-height: calc(100vh - 60px);
    min-height: calc(100svh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(32px, 6vw, 60px) 26px;
    border-bottom: 2px solid var(--ink);
  }

  .hero-inner {
    text-align: center;
    max-width: 1000px;
    width: 100%;
  }

  .hero-mark {
    margin: 0 auto clamp(20px, 4vw, 44px);
    width: clamp(60px, 10vw, 108px);
    height: clamp(60px, 10vw, 108px);
  }

  .hero-mark svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(52px, 12vw, 156px);
    line-height: 0.93;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 clamp(18px, 3vw, 40px);
    overflow-wrap: break-word;
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: clamp(11px, 1.5vw, 17px);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--red);
    margin: 0;
  }
</style>
