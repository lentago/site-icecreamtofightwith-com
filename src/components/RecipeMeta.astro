---
import { cuisineToSlug } from '../lib/cuisine';
import { redactHtml } from '../lib/redact.mjs';

interface Props {
  tier: string;
  difficultyText: string;
  totalTime: string;
  cuisine?: string;
  activeTimeMinutes?: number;
  recipeYield?: string;
  dietary?: string[];
}

const {
  tier,
  difficultyText,
  totalTime,
  cuisine,
  activeTimeMinutes,
  recipeYield,
  dietary,
} = Astro.props;

const tierClass = {
  'CHILL': 'chill',
  'LEGIT': 'legit',
  'THE REAL DEAL': 'real-deal',
  'A FUCKING ORDEAL': 'ordeal',
}[tier] || 'legit';

function formatMinutes(min?: number): string | null {
  if (min == null) return null;
  if (min < 60) return `${min} min`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m === 0 ? `${h} hr` : `${h} hr ${m} min`;
}

const activeLabel = formatMinutes(activeTimeMinutes);

const dietaryLabels: Record<string, string> = {
  'vegan': 'Vegan',
  'dairy-free': 'Dairy-free',
  'egg-free': 'Egg-free',
  'gluten-free': 'Gluten-free',
  'contains-alcohol': 'Contains alcohol',
  'contains-nuts': 'Contains nuts',
  'contains-soy': 'Contains soy',
  'contains-sesame': 'Contains sesame',
  'contains-wheat': 'Contains wheat',
};
---
<aside class="recipe-meta">
  <p class="meta-heading kicker">The Damage</p>
  <div class="meta-top">
    <span class={`tier-badge ${tierClass}`} set:html={redactHtml(tier)} />
    {cuisine && (
      <a class="meta-cuisine" href={`/cuisine/${cuisineToSlug(cuisine)}/`}>{cuisine}</a>
    )}
  </div>

  <p class="meta-difficulty" set:html={redactHtml(difficultyText)} />

  <dl class="meta-grid">
    {activeLabel && (
      <div class="meta-item">
        <dt>Active time</dt>
        <dd>{activeLabel}</dd>
      </div>
    )}
    <div class="meta-item">
      <dt>Total time</dt>
      <dd set:html={redactHtml(totalTime)} />
    </div>
    {recipeYield && (
      <div class="meta-item">
        <dt>Yield</dt>
        <dd>{recipeYield}</dd>
      </div>
    )}
  </dl>

  {dietary && dietary.length > 0 && (
    <ul class="dietary-chips" aria-label="Dietary information">
      {dietary.map(tag => (
        <li class={`chip chip-${tag.startsWith('contains-') ? 'contains' : 'free'}`}>
          {dietaryLabels[tag] ?? tag}
        </li>
      ))}
    </ul>
  )}
</aside>

<style>
  .recipe-meta {
    background: var(--panel);
    border: 3px solid var(--ink);
    padding: 1.1rem 1.35rem 1.15rem;
    margin-bottom: 2.5rem;
    box-shadow: 6px 6px 0 var(--teal);
    transform: rotate(-0.5deg);
  }

  .meta-heading {
    display: block;
    text-align: center;
    color: var(--pink);
    padding-bottom: 0.75rem;
    margin-bottom: 0.85rem;
    border-bottom: 2px dashed var(--ink);
    font-size: 0.85rem;
  }

  .meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.85rem;
  }

  .meta-cuisine {
    font-family: var(--font-stencil);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .meta-cuisine:hover { color: var(--pink); }

  .meta-difficulty {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    color: var(--ink);
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.85rem 1.25rem;
    padding-top: 0.9rem;
    border-top: 2px dashed var(--ink);
  }

  .meta-item dt {
    font-family: var(--font-stencil);
    font-weight: 700;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin-bottom: 0.2rem;
  }

  .meta-item dd {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.15rem;
    text-transform: uppercase;
  }

  .dietary-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }

  .chip {
    display: inline-block;
    font-family: var(--font-stencil);
    font-weight: 700;
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.55rem;
    border: 2px solid var(--ink);
  }

  .chip-free {
    color: #16130d;
    background: var(--teal);
  }

  .chip-contains {
    background: transparent;
    color: var(--ink-soft);
  }

  @media (max-width: 480px) {
    .meta-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
